<?xml version="1.0"?>
<model>
  <name>hexarotor_x_custom</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Andrea</name>
  </author>
  <description>
    Wrapper Gazebo per PX4_SIM_MODEL=hexarotor_x_custom: include
    hexarotor_x_custom_base (telaio + 6 link/joint rotore) e aggiunge i
    6 plugin MulticopterMotorModel richiesti dal ponte PX4-Gazebo.
    Placeholder di bring-up, vedi model.config di hexarotor_x_custom_base.
  </description>
</model>

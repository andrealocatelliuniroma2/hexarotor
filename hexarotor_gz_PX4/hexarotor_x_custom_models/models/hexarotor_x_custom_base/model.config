<?xml version="1.0"?>
<model>
  <name>hexarotor_x_custom_base</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Andrea</name>
  </author>
  <description>
    Placeholder physical model for a hexarotor X (Tarot FY680). Frame is a
    primitive-geometry hub + 6 arms (box/cylinder), sized/oriented to match
    exactly the 6 rotor positions derived from the CA_ROTORn_PX/PY of
    airframe 22004_gz_hexarotor_x_custom. Rotor mass/inertia and prop/motor
    meshes are REUSED FROM x500_base AS-IS. Body mass/inertia are still
    x500 placeholders. Replace mass, inertia and frame dimensions with
    FY680-specific data before using this for anything beyond bring-up
    testing.
  </description>
</model>
